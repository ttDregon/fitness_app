{
  "expo": {
    "name": "fitness_app",
    "slug": "my-safe-app",
    "version": "1.0.0",
    "sdkVersion": "51.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#0A0C16",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0C16"
    },
    "cli": {
      "appVersionSource": "remote"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ttdregon.mysafeapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0C16",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.ttdregon.mysafeapp",
      "googleServicesFile": "./google-services.json"
    },
    "androidNavigationBar": {
      "barStyle": "light-content",
      "backgroundColor": "#0A0C16"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#8B5CF6"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a5d7d03d-fbba-4684-bf95-86a9c4faba7b"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/a5d7d03d-fbba-4684-bf95-86a9c4faba7b"
    },
    "runtimeVersion": "1.1.0",
    "owner": "ttdregon"
  }
}
